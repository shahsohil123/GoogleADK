# ── Livekit ──────────────────────────────────────────────────────────────
# Local dev:  ws://localhost:7880
# Cloud:      wss://your-project.livekit.cloud
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── Deepgram (STT + TTS) ────────────────────────────────────────────────
# Sign up free at https://deepgram.com → 200 hours/month free tier
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── Google Gemini (voice agent brain) ───────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key
GOOGLE_GENAI_USE_VERTEXAI=false

# ── functionGemma (bash tool dispatch — loaded locally, no API key) ─────────
# The model loads automatically on first use via Hugging Face transformers.
# First run will download ~2GB of model weights.

# ── Agent workspace ─────────────────────────────────────────────────────
# Directory the bash agent operates in (default: home directory)
# WORKSPACE=/path/to/your/project
