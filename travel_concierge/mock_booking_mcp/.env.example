# Mock Booking MCP Server Configuration
# Copy to .env and customize as needed

# Debug mode (prints verbose output)
DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Booking processing simulation
# Processing time: 4-5 seconds
# Failure rate: 20% (for testing retry logic)

# Optional: Set seed for reproducible failures (for testing)
# RANDOM_SEED=42